ANTHROPIC_API_KEY=
WORKER_SECRET=
DATABASE_PATH=./data/grocery.db

# Mailbox pull. The backend polls the grocery Gmail inbox directly over IMAP, on a
# schedule and on demand (the "Check mail now" button). This is an alternative to
# the existing push path (Gmail → make.com → /inbound-email): the button pulls
# immediately instead of waiting for make.com's poll cycle.
# Gmail requires IMAP enabled (Gmail Settings → Forwarding and POP/IMAP) and an
# App Password (needs 2-Step Verification on the Google account) for IMAP_PASSWORD.
# Leave IMAP_HOST/USER/PASSWORD blank to disable pulling entirely.
IMAP_HOST=imap.gmail.com
IMAP_USER=                 # the grocery Gmail address
IMAP_PASSWORD=             # 16-char Gmail App Password, not the account password
IMAP_PORT=993
IMAP_FOLDER=INBOX
IMAP_SSL=true
POLL_INTERVAL_MINUTES=15   # how often the backend auto-pulls the mailbox; 0 disables the scheduled poll
